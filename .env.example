# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# These are server-side only (not VITE_ prefixed)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OmegaCases OAuth
OMEGACASES_CLIENT_ID=your-client-id
OMEGACASES_CLIENT_SECRET=your-client-secret
OMEGACASES_OAUTH_URL=https://omegacases.com/oauth/authorize
OMEGACASES_TOKEN_URL=https://omegacases.com/oauth/token
OMEGACASES_USER_URL=https://omegacases.com/api/user

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# App URL (your deployed URL)
APP_URL=https://omegaexchange.vercel.app
VITE_APP_URL=https://omegaexchange.vercel.app

# Tatum API (crypto wallet management)
TATUM_API_KEY=your-tatum-api-key
TATUM_TESTNET=true
